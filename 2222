<script>
document.getElementById('year').textContent = new Date().getFullYear();

/* ===================== SLIDE NAVIGATION ===================== */
const slideEls = Array.from(document.querySelectorAll('.slide'));
const navdots = document.getElementById('navdots');
const menuLinks = Array.from(document.querySelectorAll('.menubar a'));
const menubarEl = document.getElementById('menubar');
const menuToggle = document.getElementById('menuToggle');
let current = 0;
let isAnimating = false;
const TRANSITION_MS = 600;

slideEls.forEach((s, i) => {
  const dot = document.createElement('button');
  dot.title = s.dataset.title || ('Slide ' + (i+1));
  dot.addEventListener('click', () => goTo(i));
  navdots.appendChild(dot);
});
const dots = Array.from(navdots.children);

menuToggle.addEventListener('click', () => menubarEl.classList.toggle('open'));
menuLinks.forEach(a => a.addEventListener('click', () => menubarEl.classList.remove('open')));

function goTo(i){
  if(i < 0) i = slideEls.length - 1;
  if(i >= slideEls.length) i = 0;
  if(i === current || isAnimating) return;

  const goingForward = (i > current) || (current === slideEls.length - 1 && i === 0);
  const outgoing = slideEls[current];
  isAnimating = true;

  outgoing.classList.add(goingForward ? 'leaving-up' : 'leaving-down');
  outgoing.classList.remove('active');

  current = i;
  render();

  setTimeout(() => {
    outgoing.classList.remove('leaving-up', 'leaving-down');
    isAnimating = false;
  }, TRANSITION_MS);
}
function next(){ goTo(current + 1); }
function prev(){ goTo(current - 1); }

function render(){
  slideEls.forEach((s, i) => s.classList.toggle('active', i === current));
  dots.forEach((d, i) => d.classList.toggle('active', i === current));
  menuLinks.forEach(a => a.classList.toggle('active', parseInt(a.dataset.go, 10) === current));
}
slideEls[0].classList.add('active');
render();

document.querySelectorAll('[data-go]').forEach(el => {
  el.addEventListener('click', (e) => {
    e.preventDefault();
    goTo(parseInt(el.dataset.go, 10));
  });
});

document.addEventListener('contextmenu', (e) => {
  e.preventDefault();
  next();
});

window.addEventListener('keydown', (e) => {
  if (e.key === 'ArrowDown' || e.key === 'ArrowRight' || e.key === 'PageDown') next();
  if (e.key === 'ArrowUp' || e.key === 'ArrowLeft' || e.key === 'PageUp') prev();
});

document.addEventListener('click', (e) => {
  if (e.target.closest('a, button, input, .navdots, .menubar, .joy-base, .resource-chip, .menu-toggle')) return;
  if (e.clientX > window.innerWidth / 2) {
    next();
  } else {
    prev();
  }
});




/* ===================== JOYSTICK + SPIRAL ARM ===================== */
const joyBase = document.getElementById('joyBase');
const joyKnob = document.getElementById('joyKnob');
const readX = document.getElementById('readX');
const readY = document.getElementById('readY');
const trunkPath = document.getElementById('trunkPath');
const ridgesG = document.getElementById('ridges');
const tipDot = document.getElementById('tipDot');

const BASE_X = 210, BASE_Y = 400;
const NUM_SEGMENTS = 40;
const SEG_LEN = 9;
const BASE_WIDTH = 26;
const TIP_WIDTH = 3;

const ridgeMarks = [];
for (let i = 2; i < NUM_SEGMENTS - 2; i += 2) {
  const r = document.createElementNS('http://www.w3.org/2000/svg', 'path');
  r.setAttribute('stroke', 'rgba(0,0,0,0.18)');
  r.setAttribute('stroke-width', '1.4');
  r.setAttribute('fill', 'none');
  ridgesG.appendChild(r);
  ridgeMarks.push({ el: r, index: i });
}

let dragging = false;
let tx = 0, ty = 0;
let cx = 0, cy = 0;

// per-segment lagging "bend" state — each joint chases the one above it
// with its own damping + a touch of overshoot, which is what produces a
// whip-like / organic curl instead of every joint moving in lockstep.
const segBend = new Array(NUM_SEGMENTS).fill(0);
const segVel = new Array(NUM_SEGMENTS).fill(0);

// dock state
let idlePlaying = true;
let flexMult = 1;
let resetPulse = 0; // brief outward "shake" timer after Reset is pressed

function setKnobFromClient(clientX, clientY){
  const rect = joyBase.getBoundingClientRect();
  const cxBase = rect.left + rect.width/2;
  const cyBase = rect.top + rect.height/2;
  let dx = clientX - cxBase;
  let dy = clientY - cyBase;
  const max = rect.width/2 - 27;
  const dist = Math.hypot(dx, dy);
  if (dist > max) { dx = dx/dist*max; dy = dy/dist*max; }
  joyKnob.style.left = `calc(50% + ${dx}px)`;
  joyKnob.style.top = `calc(50% + ${dy}px)`;
  tx = dx / max;
  ty = dy / max;
  readX.textContent = tx.toFixed(2);
  readY.textContent = ty.toFixed(2);
}

function resetKnob(){
  joyKnob.style.left = '50%';
  joyKnob.style.top = '50%';
  tx = 0; ty = 0;
  readX.textContent = '0.00';
  readY.textContent = '0.00';
}

/* ---- dock controls ---- */
const dockPlay = document.getElementById('dockPlay');
const dockPlayIcon = document.getElementById('dockPlayIcon');
const dockPlayLabel = document.getElementById('dockPlayLabel');
const dockReset = document.getElementById('dockReset');
const dockSpeed = document.getElementById('dockSpeed');
const dockSpeedVal = document.getElementById('dockSpeedVal');

dockPlay.addEventListener('click', () => {
  idlePlaying = !idlePlaying;
  dockPlay.classList.toggle('is-active', idlePlaying);
  dockPlayLabel.textContent = idlePlaying ? 'Pause idle' : 'Play idle';
  dockPlayIcon.innerHTML = idlePlaying
    ? '<rect x="6" y="5" width="4" height="14"></rect><rect x="14" y="5" width="4" height="14"></rect>'
    : '<polygon points="6 4 20 12 6 20 6 4"></polygon>';
});

dockReset.addEventListener('click', () => {
  resetKnob();
  segBend.fill(0);
  segVel.fill(0);
  resetPulse = 1;
});

dockSpeed.addEventListener('input', () => {
  flexMult = parseFloat(dockSpeed.value);
  dockSpeedVal.textContent = flexMult.toFixed(1) + '×';
});

joyKnob.addEventListener('pointerdown', (e) => {
  dragging = true;
  joyKnob.style.cursor = 'grabbing';
  joyKnob.setPointerCapture(e.pointerId);
});
window.addEventListener('pointermove', (e) => {
  if (!dragging) return;
  setKnobFromClient(e.clientX, e.clientY);
});
window.addEventListener('pointerup', () => {
  if (!dragging) return;
  dragging = false;
  joyKnob.style.cursor = 'grab';
  resetKnob();
});

function animate(){
  cx += (tx - cx) * 0.10;
  cy += (ty - cy) * 0.10;
  const t = performance.now() / 1000;

  if (resetPulse > 0) resetPulse = Math.max(0, resetPulse - 0.045);

  const dist = Math.min(1, Math.hypot(cx, cy));
  const dirSign = cx < 0 ? -1 : 1;
  const curlAmount = dist * 16 * dirSign * flexMult;

  let angle = -90;
  let px = BASE_X, py = BASE_Y;
  const pts = [{x: px, y: py}];

  for (let i = 0; i < NUM_SEGMENTS; i++) {
    const f = i / (NUM_SEGMENTS - 1);
    const curlGain = 0.2 + f * 0.6;

    // ambient sway only plays while idle motion is on, and fades out
    // the more the joystick is actively driving the arm
    const idle = idlePlaying
      ? Math.sin(t * 0.5 + i * 0.25) * 0.06 * f * (1 - dist) * flexMult
      : 0;

    // target bend this joint "wants" — same as before, but now it's a
    // target rather than the applied value
    const target = curlAmount * curlGain + idle;

    // each joint is a lightly damped spring chasing its target, and also
    // gets pulled toward the joint just above it in the chain. Lower
    // stiffness + a little inherited motion from the previous segment is
    // what produces the lagging, whip-like curl instead of every segment
    // snapping to the same angle in lockstep.
    const prevBend = i === 0 ? target : segBend[i - 1];
    const chainPull = (prevBend - segBend[i]) * (0.10 + f * 0.10);
    const springForce = (target - segBend[i]) * (0.16 - f * 0.06);
    const damping = 0.78 - f * 0.08; // tip segments carry a touch more momentum

    segVel[i] = (segVel[i] + springForce + chainPull) * damping;
    segBend[i] += segVel[i];

    // brief outward shake right after Reset, biggest near the tip
    const shake = resetPulse > 0 ? Math.sin(t * 30 + i) * resetPulse * 1.4 * f : 0;

    angle += segBend[i] + shake;
    px += Math.cos(angle * Math.PI / 180) * SEG_LEN;
    py += Math.sin(angle * Math.PI / 180) * SEG_LEN;
    pts.push({x: px, y: py});
  }

  const left = [], right = [];
  for (let i = 0; i < pts.length; i++) {
    const w = (BASE_WIDTH + (TIP_WIDTH - BASE_WIDTH) * (i / (pts.length - 1))) / 2;
    const prev = pts[Math.max(0, i - 1)];
    const nextP = pts[Math.min(pts.length - 1, i + 1)];
    const dx = nextP.x - prev.x, dy = nextP.y - prev.y;
    const len = Math.hypot(dx, dy) || 1;
    const nx = -dy / len, ny = dx / len;
    left.push({ x: pts[i].x + nx * w, y: pts[i].y + ny * w });
    right.push({ x: pts[i].x - nx * w, y: pts[i].y - ny * w });
  }

  let d = `M ${left[0].x.toFixed(1)} ${left[0].y.toFixed(1)} `;
  for (let i = 1; i < left.length; i++) d += `L ${left[i].x.toFixed(1)} ${left[i].y.toFixed(1)} `;
  for (let i = right.length - 1; i >= 0; i--) d += `L ${right[i].x.toFixed(1)} ${right[i].y.toFixed(1)} `;
  d += 'Z';
  trunkPath.setAttribute('d', d);

  ridgeMarks.forEach(({ el, index }) => {
    const w = (BASE_WIDTH + (TIP_WIDTH - BASE_WIDTH) * (index / (pts.length - 1))) * 0.42;
    const p = pts[index];
    const dx = pts[index + 1].x - pts[index - 1].x;
    const dy = pts[index + 1].y - pts[index - 1].y;
    const len = Math.hypot(dx, dy) || 1;
    const nx = -dy / len, ny = dx / len;
    el.setAttribute('d', `M ${p.x - nx*w} ${p.y - ny*w} L ${p.x + nx*w} ${p.y + ny*w}`);
  });

  const tip = pts[pts.length - 1];
  tipDot.setAttribute('cx', tip.x);
  tipDot.setAttribute('cy', tip.y);

  requestAnimationFrame(animate);
}
animate();
</script>

